# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/associazione_db
# URL del proprietario dello schema, usato per le migrazioni (DDL). Se assente,
# ricade su DATABASE_URL.
# MIGRATION_DATABASE_URL=postgresql+asyncpg://associazione:associazione@localhost:5432/associazione_db

# App
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=changeme

# Autenticazione
JWT_SECRET_KEY=changeme
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
SESSION_EXPIRE_HOURS=12
SESSION_COOKIE_NAME=session_token
SESSION_COOKIE_SECURE=false
# Password del superuser di bootstrap creato dalla migrazione auth.
BOOTSTRAP_ADMIN_PASSWORD=changeme

# Email (Resend — https://resend.com)
RESEND_API_KEY=
FRONTEND_URL=https://bandapp-web-fe.vercel.app
